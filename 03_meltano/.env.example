# Meltano Kafka → S3 pipeline – copy to .env and fill in
# See https://docs.meltano.com/getting-started/

# ----- Kafka (tap-kafka) -----
# Override if not using defaults from meltano.yml
# TAP_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# TAP_KAFKA_TOPIC=postgres1.inventory.customers
# TAP_KAFKA_GROUP_ID=meltano-kafka-to-s3

# ----- S3 (target-s3) – required -----
TARGET_S3_CLOUD_PROVIDER_AWS_AWS_BUCKET=your-bucket-name
TARGET_S3_CLOUD_PROVIDER_AWS_AWS_ACCESS_KEY_ID=your-access-key
TARGET_S3_CLOUD_PROVIDER_AWS_AWS_SECRET_ACCESS_KEY=your-secret-key
# Optional if different from meltano.yml
# TARGET_S3_CLOUD_PROVIDER_AWS_AWS_REGION=us-east-1
